// ── Export ──
function buildExportText(r){
  const b = r.basics;
  const lines = [];
  const d = b.date ? new Date(b.date+'T12:00:00').toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'}) : b.date;
  lines.push('INSTRUCTIONAL WALKTHROUGH RECORD');
  lines.push('=================================');
  lines.push('Teacher: '+b.teacher+'   Date: '+d);
  lines.push('Class: '+b.subject+'   Grade: '+b.grade+'   Time: '+(b.timeIn||'')+'–'+(b.timeOut||''));
  lines.push('Focus: '+b.focus+'   Teacher goal: '+b.goal);
  lines.push('');
  lines.push('HIGH-IMPACT STRATEGIES');
  lines.push('----------------------');
  HIS.forEach(h=>{
    const e=r.highImpact[h.id]||{};
    lines.push('['+((e.status||'—').toUpperCase())+'] '+h.label);
    if(e.notes) lines.push('   → '+e.notes);
  });
  lines.push('');
  lines.push('STUDENT ENGAGEMENT');
  lines.push('------------------');
  const pct = r.engagement.present>0?Math.round(r.engagement.engaged/r.engagement.present*100):0;
  lines.push('Present: '+r.engagement.present+'   Engaged: '+r.engagement.engaged+' ('+pct+'%)');
  ENG.forEach(e=>{
    const s=r.engagement.indicators[e.id];
    if(s) lines.push('['+s.toUpperCase()+'] '+e.label);
  });
  if(r.engagement.evidenceNotes) lines.push('Evidence: '+r.engagement.evidenceNotes);
  lines.push('');
  lines.push('STRENGTHS AND NEXT STEP');
  lines.push('-----------------------');
  if(r.strengthsNext.strength1) lines.push('Strength 1: '+r.strengthsNext.strength1);
  if(r.strengthsNext.strength2) lines.push('Strength 2: '+r.strengthsNext.strength2);
  if(r.strengthsNext.nextStep) lines.push('Next step: '+r.strengthsNext.nextStep);
  lines.push('Discussed with teacher: '+(r.strengthsNext.discussed?'Yes':'No'));
  if(r.strengthsNext.teacherReflect) lines.push('Teacher reflection: '+r.strengthsNext.teacherReflect);
  lines.push('');
  lines.push('COACHING CYCLE');
  lines.push('--------------');
  lines.push('Stage: '+r.coachingCycle.stage);
  lines.push('Goal alignment: '+r.coachingCycle.goalAlignment);
  lines.push('Moves goal forward: '+(r.coachingCycle.movesForward?'Yes':'No'));
  if(r.coachingCycle.observerNotes) lines.push('Observer notes: '+r.coachingCycle.observerNotes);
  return lines.join('\n');
}

function exportText(){
  const r = gatherForm();
  navigator.clipboard.writeText(buildExportText(r)).then(()=>showToast('Copied to clipboard')).catch(()=>showToast('Done'));
}

function exportCurrentRecord(){
  const r = getRecords().find(x=>x.id===detailId);
  if(!r) return;
  navigator.clipboard.writeText(buildExportText(r)).then(()=>showToast('Copied to clipboard')).catch(()=>showToast('Done'));
}

function showToast(msg){
  const t=document.getElementById('toast');
  t.textContent=msg; t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'),2200);
}

// ── Apps Script sync ──
const GAS_URL_KEY = 'wt_gas_url';
const GAS_URL_DEFAULT = 'https://script.google.com/macros/s/AKfycbwyqBUhg-4fPNSCJz77fmiciRqi0ZBtBWVejtGJdOaPyIPhbiqNRWNynJCfXQzyciWqtA/exec';

function getGasUrl(){ return localStorage.getItem(GAS_URL_KEY) || GAS_URL_DEFAULT; }

// GET with URL-encoded data — most reliable approach for Apps Script
function gasGet(url, params){
  const qs = Object.entries(params).map(([k,v]) => encodeURIComponent(k)+'='+encodeURIComponent(v)).join('&');
  return fetch(url+'?'+qs);
}

function saveRecord(){
  const r = gatherForm();
  if(!r.basics.teacher){ showToast('Add a teacher name first'); return; }
  let records = getRecords();
  const idx = records.findIndex(x => x.id === r.id);
  if(idx >= 0) records[idx] = r;
  else records.unshift(r);
  saveRecords(records);
  editingId = null;
  document.getElementById('edit-banner').style.display = 'none';

  const gasUrl = getGasUrl();
  setSyncStatus('syncing');
  gasGet(gasUrl, {action: 'upsert', data: JSON.stringify(r)})
    .then(res => res.json())
    .then(data => {
      if(data.status === 'ok'){
        setSyncStatus('synced');
        showToast('Saved and synced to Sheet');
      } else {
        setSyncStatus('error');
        showToast('Saved locally — sync error: '+(data.message||''));
      }
    })
    .catch(() => {
      setSyncStatus('error');
      showToast('Saved locally — offline');
    });

  clearForm(false);
  setTimeout(()=>showView('records'), 900);
}

function deleteRecord(){
  if(!confirm('Delete this record permanently?')) return;
  const gasUrl = getGasUrl();
  gasGet(gasUrl, {action: 'delete', id: detailId}).catch(()=>{});
  let records = getRecords().filter(x=>x.id!==detailId);
  saveRecords(records);
  showToast('Record deleted');
  showView('records');
}

function setSyncStatus(state){
  const el = document.getElementById('sync-status');
  if(!el) return;
  const states = {
    syncing: {text:'Syncing...', color:'var(--text2)'},
    synced:  {text:'Synced to Sheet', color:'var(--success)'},
    error:   {text:'Sync failed — saved locally', color:'var(--danger)'},
    none:    {text:'Sheet connected', color:'var(--text3)'}
  };
  const s = states[state]||states.none;
  el.textContent = s.text;
  el.style.color = s.color;
}

function openSettings(){
  document.getElementById('settings-modal').style.display = 'flex';
  document.getElementById('gas-url-input').value = getGasUrl();
}
function closeSettings(){
  document.getElementById('settings-modal').style.display = 'none';
}
function saveSettings(){
  const url = document.getElementById('gas-url-input').value.trim();
  localStorage.setItem(GAS_URL_KEY, url || GAS_URL_DEFAULT);
  closeSettings();
  showToast('Settings saved');
  testConnection(url || GAS_URL_DEFAULT);
}
function testConnection(url){
  setSyncStatus('syncing');
  fetch(url+'?action=ping')
    .then(r=>r.json())
    .then(d=>{ setSyncStatus(d.status==='ok'?'none':'error'); showToast(d.status==='ok'?'Connection verified':'Connection failed'); })
    .catch(()=>{ setSyncStatus('error'); showToast('Could not reach Sheet'); });
}

function exportAllJSON(){
  const records = getRecords();
  const blob = new Blob([JSON.stringify(records, null, 2)], {type:'application/json'});
  const a = document.createElement('a');
  a.href = URL.createObjectURL(blob);
  a.download = 'walkthrough-records-'+new Date().toISOString().split('T')[0]+'.json';
  a.click();
}
function importJSON(){
  const input = document.createElement('input');
  input.type='file'; input.accept='.json';
  input.onchange = e => {
    const file = e.target.files[0];
    const reader = new FileReader();
    reader.onload = ev => {
      try {
        const imported = JSON.parse(ev.target.result);
        if(!Array.isArray(imported)) throw new Error();
        const existing = getRecords();
        const existingIds = new Set(existing.map(r=>r.id));
        const merged = [...existing, ...imported.filter(r=>!existingIds.has(r.id))];
        saveRecords(merged);
        showToast(imported.length+' records imported');
        renderRecords();
      } catch(e){ showToast('Invalid file'); }
    };
    reader.readAsText(file);
  };
  input.click();
}

// ── Init ──
buildHIS();
buildENG();
document.getElementById('f-date').value = new Date().toISOString().split('T')[0];
testConnection(getGasUrl());
</script>

