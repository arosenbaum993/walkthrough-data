      }).join('')}
    </div>
    <div class="detail-section">
      <div class="detail-section-title">Student engagement</div>
      ${row('Present', r.engagement.present)}
      ${row('Engaged', r.engagement.engaged+(r.engagement.present>0?' ('+Math.round(r.engagement.engaged/r.engagement.present*100)+'%)':''))}
      ${ENG.map(e=>{
        const s = r.engagement.indicators[e.id];
        if(!s) return '';
        return `<div class="detail-row"><span class="detail-val" style="flex:1;font-size:12px">${e.label}</span>
          <span class="status-pill ${spClass(s)}">${spLabel(s)}</span></div>`;
      }).join('')}
      ${r.engagement.evidenceNotes?`<div class="detail-row"><span class="detail-key">Evidence</span><span class="detail-val" style="font-size:12px">${r.engagement.evidenceNotes}</span></div>`:''}
    </div>
    <div class="detail-section">
      <div class="detail-section-title">Strengths and next step</div>
      ${r.strengthsNext.strength1?row('Strength 1', r.strengthsNext.strength1):''}
      ${r.strengthsNext.strength2?row('Strength 2', r.strengthsNext.strength2):''}
      ${r.strengthsNext.nextStep?row('Next step', r.strengthsNext.nextStep):''}
      ${row('Discussed', r.strengthsNext.discussed?'Yes':'No')}
      ${r.strengthsNext.teacherReflect?row('Teacher reflection', r.strengthsNext.teacherReflect):''}
    </div>
    <div class="detail-section">
      <div class="detail-section-title">Coaching cycle</div>
      ${row('Stage', r.coachingCycle.stage)}
      ${row('Goal alignment', r.coachingCycle.goalAlignment)}
      ${row('Moves goal forward', r.coachingCycle.movesForward?'Yes':'No')}
      ${r.coachingCycle.observerNotes?row('Observer notes', r.coachingCycle.observerNotes):''}
    </div>
  `;
  document.getElementById('detail-body').innerHTML = html;
  showView('detail');
}

function row(k, v){ if(!v&&v!==0) return ''; return `<div class="detail-row"><span class="detail-key">${k}</span><span class="detail-val">${v}</span></div>`; }

function editRecord(){
  const r = getRecords().find(x=>x.id===detailId);
