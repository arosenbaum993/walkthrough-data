// ── Storage ──
function getRecords(){ return JSON.parse(localStorage.getItem('wt_records')||'[]'); }
function saveRecords(r){ localStorage.setItem('wt_records', JSON.stringify(r)); }

// ── Gather form data ──
function gatherForm(){
  const his = {};
  HIS.forEach(h => { his[h.id] = {status: getPillVal('pg-'+h.id), notes: document.getElementById('hn-'+h.id).value}; });
  const eng = {};
  ENG.forEach(e => { eng[e.id] = getPillVal('pg-eng-'+e.id); });
  return {
    id: editingId || Date.now().toString(),
    savedAt: new Date().toISOString(),
    basics: {
      teacher: document.getElementById('f-teacher').value,
      date: document.getElementById('f-date').value,
      subject: document.getElementById('f-subject').value,
      grade: document.getElementById('f-grade').value,
      timeIn: document.getElementById('f-timein').value,
      timeOut: document.getElementById('f-timeout').value,
      focus: document.getElementById('f-focus').value,
      goal: document.getElementById('f-goal').value
    },
    highImpact: his,
    engagement: {
      present: tallies.present,
      engaged: tallies.engaged,
      indicators: eng,
      evidenceNotes: document.getElementById('f-eng-notes').value
    },
    strengthsNext: {
      strength1: document.getElementById('f-str1').value,
      strength2: document.getElementById('f-str2').value,
      nextStep: document.getElementById('f-nextstep').value,
      discussed: document.getElementById('f-discussed').checked,
      teacherReflect: document.getElementById('f-treflect').value
    },
    coachingCycle: {
      stage: document.getElementById('f-stage').value,
      goalAlignment: document.getElementById('f-goalign').value,
      movesForward: document.getElementById('f-moves').checked,
      observerNotes: document.getElementById('f-obsnotes').value
    }
  };
}

function saveRecord(){
  const r = gatherForm();
  if(!r.basics.teacher){ showToast('Add a teacher name first'); return; }
  let records = getRecords();
  const idx = records.findIndex(x => x.id === r.id);
  if(idx >= 0) records[idx] = r;
  else records.unshift(r);
  saveRecords(records);
  editingId = null;
  document.getElementById('edit-banner').style.display = 'none';
  showToast('Record saved');
  clearForm(false);
  setTimeout(()=>showView('records'), 800);
}

// ── Fill form from record ──
function fillForm(r){
  const b = r.basics;
  document.getElementById('f-teacher').value = b.teacher||'';
  document.getElementById('f-date').value = b.date||'';
  document.getElementById('f-subject').value = b.subject||'';
  document.getElementById('f-grade').value = b.grade||'';
  document.getElementById('f-timein').value = b.timeIn||'';
  document.getElementById('f-timeout').value = b.timeOut||'';
  document.getElementById('f-focus').value = b.focus||'';
  document.getElementById('f-goal').value = b.goal||'';
  HIS.forEach(h => {
    const d = r.highImpact[h.id]||{};
    if(d.status) setPillVal('pg-'+h.id, d.status);
    document.getElementById('hn-'+h.id).value = d.notes||'';
  });
  tallies.present = r.engagement.present||0;
  tallies.engaged = r.engagement.engaged||0;
  document.getElementById('tv-present').textContent = tallies.present;
  document.getElementById('tv-engaged').textContent = tallies.engaged;
  adj('engaged',0);
  ENG.forEach(e => { if(r.engagement.indicators[e.id]) setPillVal('pg-eng-'+e.id, r.engagement.indicators[e.id]); });
  document.getElementById('f-eng-notes').value = r.engagement.evidenceNotes||'';
  document.getElementById('f-str1').value = r.strengthsNext.strength1||'';
  document.getElementById('f-str2').value = r.strengthsNext.strength2||'';
  document.getElementById('f-nextstep').value = r.strengthsNext.nextStep||'';
  document.getElementById('f-discussed').checked = !!r.strengthsNext.discussed;
  document.getElementById('f-treflect').value = r.strengthsNext.teacherReflect||'';
  document.getElementById('f-stage').value = r.coachingCycle.stage||'';
  document.getElementById('f-goalign').value = r.coachingCycle.goalAlignment||'';
  document.getElementById('f-moves').checked = !!r.coachingCycle.movesForward;
  document.getElementById('f-obsnotes').value = r.coachingCycle.observerNotes||'';
}

function clearForm(toast=true){
  ['f-teacher','f-subject','f-grade','f-timein','f-timeout','f-goal','f-eng-notes','f-str1','f-str2','f-nextstep','f-treflect','f-goalign','f-obsnotes'].forEach(id=>{
    const el = document.getElementById(id); if(el) el.value='';
  });
  document.getElementById('f-date').value = new Date().toISOString().split('T')[0];
  document.getElementById('f-focus').value='';
  document.getElementById('f-stage').value='';
  document.getElementById('f-discussed').checked=false;
  document.getElementById('f-moves').checked=false;
  document.querySelectorAll('.pill').forEach(p=>{ p.classList.remove('sel-obs','sel-not','sel-na'); delete p.dataset.sel; });
  tallies={present:0,engaged:0};
  document.getElementById('tv-present').textContent='0';
  document.getElementById('tv-engaged').textContent='0';
  document.getElementById('ratio-badge').style.display='none';
  editingId=null;
  document.getElementById('edit-banner').style.display='none';
  if(toast) showToast('Form cleared');
}

// ── Records rendering ──
function renderRecords(){
  const records = getRecords();
  const q = (document.getElementById('search-input').value||'').toLowerCase();
  const filtered = q ? records.filter(r => {
    const b = r.basics;
    return [b.teacher,b.subject,b.grade,b.focus,b.goal].join(' ').toLowerCase().includes(q);
  }) : records;

  document.getElementById('rec-count').textContent = filtered.length + ' record' + (filtered.length!==1?'s':'');

  // Stats
  const statsArea = document.getElementById('stats-area');
  const teachers = [...new Set(records.map(r=>r.basics.teacher).filter(Boolean))];
  statsArea.innerHTML = `
    <div class="stats-grid">
      <div class="stat-card"><div class="stat-num">${records.length}</div><div class="stat-label">Total visits</div></div>
      <div class="stat-card"><div class="stat-num">${teachers.length}</div><div class="stat-label">Teachers</div></div>
      <div class="stat-card"><div class="stat-num">${records.filter(r=>r.strengthsNext&&r.strengthsNext.discussed).length}</div><div class="stat-label">Post-conferences</div></div>
    </div>
  `;

  const list = document.getElementById('records-list');
  if(filtered.length===0){
    list.innerHTML = `<div class="empty-state"><div class="big">📋</div><p>${q?'No records match your search.':'No records yet.<br>Complete a visit form to get started.'}</p></div>`;
    return;
  }
  list.innerHTML = filtered.map(r => {
    const b = r.basics;
    const d = b.date ? new Date(b.date+'T12:00:00').toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}) : '';
    const stage = r.coachingCycle&&r.coachingCycle.stage ? r.coachingCycle.stage : '';
    const focus = b.focus||'';
    const pct = r.engagement&&r.engagement.present>0 ? Math.round(r.engagement.engaged/r.engagement.present*100)+'% engaged' : '';
    return `
      <div class="record-card" onclick="openDetail('${r.id}')">
        <div class="record-card-top">
          <div>
            <div class="record-teacher">${b.teacher||'Unnamed teacher'}</div>
            <div class="record-meta">${[b.subject, b.grade?'Grade '+b.grade:'', d].filter(Boolean).join(' · ')}</div>
          </div>
          <div style="font-size:12px;color:var(--text3);flex-shrink:0">${b.timeIn||''}</div>
        </div>
        <div class="record-badges">
          ${focus?`<span class="badge badge-blue">${focus}</span>`:''}
          ${stage?`<span class="badge badge-green">${stage}</span>`:''}
          ${pct?`<span class="badge badge-gray">${pct}</span>`:''}
        </div>
      </div>
    `;
  }).join('');
}

// ── Detail view ──
function openDetail(id){
  detailId = id;
  const r = getRecords().find(x=>x.id===id);
  if(!r) return;
  const b = r.basics;
  const d = b.date ? new Date(b.date+'T12:00:00').toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric',year:'numeric'}) : '';
  document.getElementById('detail-title').textContent = b.teacher||'Record';

  const spClass = s => s==='observed'?'sp-obs':s==='not-observed'?'sp-not':'sp-na';
  const spLabel = s => s==='observed'?'Observed':s==='not-observed'?'Not observed':s==='na'?'N/A':'—';

  let html = `
    <div class="detail-section">
      <div class="detail-section-title">Basics</div>
      ${row('Teacher', b.teacher)} ${row('Date', d)} ${row('Class', b.subject)} ${row('Grade', b.grade)}
      ${row('Time', [b.timeIn,b.timeOut].filter(Boolean).join(' – '))}
      ${row('Focus', b.focus)} ${row('Teacher goal', b.goal)}
    </div>
    <div class="detail-section">
      <div class="detail-section-title">High-impact strategies</div>
      ${HIS.map(h=>{
        const e = r.highImpact[h.id]||{};
        return `<div class="detail-row"><span class="detail-val" style="flex:1;font-size:12px;line-height:1.4">${h.label}</span>
          <span class="status-pill ${spClass(e.status)}">${spLabel(e.status)}</span></div>
